# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── External APIs ─────────────────────────────────────────────
# CoinGecko: free tier works; Pro key increases rate limits
COINGECKO_API_KEY=

# CoinMarketCap: basic plan required ($0 free tier works)
CMC_API_KEY=

# GitHub: fine-grained PAT with public repo read access
GITHUB_TOKEN=ghp_...

# Twitter/X Bearer Token (Elevated access for search/timeline)
# Free Basic tier works for moderate volume
TWITTER_BEARER_TOKEN=

# ── System ───────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
